generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id                         String                      @id @default(cuid())
  name                       String
  phone                      String
  email                      String?
  buyerType                  String
  location                   String?
  paymentTerms               String                      @default("Full payment before order allocation")
  creditLimit                Int                         @default(0)
  outstandingBalance         Int                         @default(0)
  accountStatus              String                      @default("Manual WhatsApp")
  accountLoginReady          Boolean                     @default(false)
  receiptEmail               String?
  approvedBy                 String?
  approvedAt                 DateTime?
  status                     String                      @default("Active")
  orders                     Order[]
  receipts                   Receipt[]
  buyerContacts              BuyerContact[]
  buyerInvites               BuyerAccountInvite[]
  buyerProfileUpdateRequests BuyerProfileUpdateRequest[]
  buyerMessages              BuyerMessage[]
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  paymentRequests            PaymentRequest[]
  deliveries                 Delivery[]
}

model Product {
  id           String      @id @default(cuid())
  name         String
  category     String
  unit         String
  grade        String      @default("Standard")
  basePrice    Int         @default(0)
  availability String      @default("Available")
  status       String      @default("Active")
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  type          String
  phone         String?
  location      String
  produceFocus  String
  reliability   String   @default("Unrated")
  paymentMethod String   @default("Bank transfer")
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id               String           @id @default(cuid())
  code             String           @unique
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id])
  buyerName        String
  phone            String
  buyerType        String
  orderType        String
  paymentStatus    String           @default("Unpaid")
  fulfilmentStatus String           @default("New order")
  deliveryMethod   String
  deliveryNote     String?
  source           String           @default("Admin")
  sourcePhone      String?
  buyerContactId   String?
  subtotal         Int              @default(0)
  deliveryFee      Int              @default(0)
  serviceFee       Int              @default(0)
  discountAmount   Int              @default(0)
  totalAmount      Int              @default(0)
  paymentReference String?
  estimatedTotal   Int              @default(0)
  adminNote        String?
  items            OrderItem[]
  payments         Payment[]
  complaints       Complaint[]
  receipts         Receipt[]
  paymentRequests  PaymentRequest[]
  delivery         Delivery?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  grade     String
  quantity  Int
  unit      String
  unitPrice Int
  lineTotal Int
}

model GroupBuy {
  id               String                @id @default(cuid())
  code             String                @unique
  title            String
  description      String?
  status           String                @default("Draft")
  minQuantity      Int                   @default(0)
  targetQuantity   Int                   @default(0)
  reservedQuantity Int                   @default(0)
  unit             String                @default("unit")
  closingDate      DateTime?
  pickupWindow     String?
  paymentStatus    String                @default("Collecting payments")
  fulfilmentStatus String                @default("Planning")
  adminNote        String?
  items            GroupBuyItem[]
  reservations     GroupBuyReservation[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model GroupBuyItem {
  id         String   @id @default(cuid())
  groupBuyId String
  groupBuy   GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  productId  String?
  name       String
  grade      String
  quantity   Int
  unit       String
  unitPrice  Int
  lineTotal  Int
}

model GroupBuyReservation {
  id            String   @id @default(cuid())
  groupBuyId    String
  groupBuy      GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  buyerName     String
  phone         String
  buyerType     String
  quantity      Int
  amount        Int
  paymentStatus String   @default("Unpaid")
  createdAt     DateTime @default(now())
}

model Payment {
  id        String    @id @default(cuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id])
  reference String    @unique
  provider  String
  amount    Int
  status    String
  paidAt    DateTime?
  receipts  Receipt[]
  createdAt DateTime  @default(now())
}

model Complaint {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  code       String   @unique
  issue      String
  priority   String
  status     String   @default("Open")
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PickupLocation {
  id        String   @id @default(cuid())
  name      String
  area      String
  address   String
  fee       Int      @default(0)
  days      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("Operations")
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(cuid())
  actorName     String   @default("Local admin")
  actorEmail    String?
  actorRole     String   @default("Admin")
  action        String
  entityType    String
  entityId      String?
  entityLabel   String?
  previousValue String?
  newValue      String?
  metadata      String?
  createdAt     DateTime @default(now())
}

model Receipt {
  id         String    @id @default(cuid())
  code       String    @unique
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  paymentId  String?
  payment    Payment?  @relation(fields: [paymentId], references: [id])
  buyerName  String
  buyerEmail String?
  amount     Int
  status     String    @default("Issued")
  issuedBy   String    @default("Local admin")
  issuedAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())
}

model BuyerContact {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  role            String   @default("Buyer user")
  canPlaceOrders  Boolean  @default(true)
  canViewReceipts Boolean  @default(true)
  canViewCredit   Boolean  @default(false)
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BuyerAccountInvite {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  inviteCode String    @unique
  email      String?
  phone      String?
  role       String    @default("Buyer user")
  status     String    @default("Draft")
  expiresAt  DateTime?
  sentAt     DateTime?
  acceptedAt DateTime?
  createdBy  String    @default("Local staff user")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model BuyerMessage {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title       String
  body        String
  channel     String  @default("Portal")
  direction   String  @default("Outbound")
  status      String  @default("Logged")
  recipient   String?
  source      String  @default("System")
  relatedType String?
  relatedId   String?
  metadata    String?

  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model BuyerProfileUpdateRequest {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  requestType   String   @default("Profile update")
  companyInfo   String?
  buyingProfile String?
  financeInfo   String?
  contactInfo   String?
  documentsNote String?
  message       String?
  status        String   @default("New")
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactEnquiry {
  id           String   @id @default(cuid())
  name         String
  organisation String?
  email        String?
  phone        String?
  enquiryType  String   @default("General enquiry")
  message      String
  status       String   @default("New")
  source       String   @default("Contact page")
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BuyerAccountRequest {
  id                     String   @id @default(cuid())
  contactName            String
  organisationName       String?
  buyerType              String   @default("Business buyer")
  phone                  String
  email                  String?
  location               String?
  usualProduceNeeds      String?
  orderFrequency         String?
  estimatedSpend         String?
  businessRegNumber      String?
  preferredPaymentMethod String?
  needsReceipts          Boolean  @default(true)
  interestedInCredit     Boolean  @default(false)
  message                String?
  status                 String   @default("New")
  source                 String   @default("Buyer account request page")
  adminNote              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model OrderRequest {
  id                 String   @id @default(cuid())
  buyerName          String
  buyerType          String   @default("Household / individual")
  phone              String
  email              String?
  location           String?
  deliveryPreference String   @default("Delivery")
  items              String
  timing             String?
  groupBuyInterest   Boolean  @default(false)
  message            String?
  status             String   @default("New")
  source             String   @default("Order request page")
  adminNote          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DeliveryPartner {
  id           String     @id @default(cuid())
  name         String
  contactName  String?
  phone        String?
  email        String?
  serviceArea  String?
  status       String     @default("Active")
  notes        String?
  deliveries   Delivery[]
  accessCode   String?    @unique
  accessStatus String     @default("Not invited")
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PaymentRequest {
  id               String    @id @default(cuid())
  orderId          String
  customerId       String?
  provider         String    @default("Manual")
  reference        String    @unique
  amount           Int
  currency         String    @default("NGN")
  status           String    @default("Pending")
  paymentUrl       String?
  bankName         String?
  accountNumber    String?
  accountName      String?
  gatewayReference String?
  expiresAt        DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
}

model Delivery {
  id                   String    @id @default(cuid())
  orderId              String    @unique
  customerId           String?
  deliveryPartnerId    String?
  deliveryMethod       String    @default("OneFarmTech arranged")
  deliveryPartnerName  String?
  deliveryPartnerPhone String?
  deliveryFee          Int       @default(0)
  deliveryAddress      String?
  deliveryArea         String?
  preferredDate        DateTime?
  status               String    @default("Pending")
  trackingReference    String?
  proofOfDeliveryNote  String?
  deliveredAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer        Customer?        @relation(fields: [customerId], references: [id])
  deliveryPartner DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
}

model EmailDelivery {
  id                String               @id @default(cuid())
  deduplicationKey  String               @unique
  template          String
  recipient         String
  subject           String
  textBody          String
  htmlBody          String
  status            String               @default("Pending")
  provider          String               @default("Resend")
  providerMessageId String?
  relatedType       String?
  relatedId         String?
  lastError         String?
  retryCount        Int                  @default(0)
  acceptedAt        DateTime?
  failedAt          DateTime?
  lastAttemptAt     DateTime?
  latestEventId     String?              @unique
  latestEventType   String?
  latestEventAt     DateTime?
  eventMetadata     String?
  nextRetryAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  providerEvents    EmailProviderEvent[]

  @@index([status, createdAt])
  @@index([relatedType, relatedId])
}

model EmailProviderEvent {
  id                String         @id @default(cuid())
  eventId           String         @unique
  emailDeliveryId   String?
  emailDelivery     EmailDelivery? @relation(fields: [emailDeliveryId], references: [id], onDelete: SetNull)
  providerMessageId String
  eventType         String
  eventAt           DateTime
  matched           Boolean        @default(false)
  metadata          String?
  createdAt         DateTime       @default(now())

  @@index([providerMessageId, eventAt])
  @@index([emailDeliveryId, eventAt])
}

model PaymentReconciliationIncident {
  id                   String    @id @default(cuid())
  provider             String
  internalReference    String?
  providerReference    String?
  reason               String
  payloadMetadata      String?
  verificationMetadata String?
  status               String    @default("Open")
  resolutionNote       String?
  resolvedByName       String?
  resolvedByEmail      String?
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([provider, internalReference])
  @@index([status, createdAt])
}

model OperationalEvent {
  id          String   @id @default(cuid())
  category    String
  severity    String   @default("Error")
  summary     String
  route       String?
  relatedType String?
  relatedId   String?
  metadata    String?
  status      String   @default("Open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([category, createdAt])
}
